{
  "name": "thriveagric-payment-api",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
  "dev":  "docker-compose up --remove-orphans",
  "dev:build":  "docker-compose up --build --remove-orphans",
  "docker:down":  "docker-compose down",
  "docker:restart": "docker-compose restart",
  "start:dev": "ts-node-dev --respawn --transpile-only  --poll src/app.ts",
  "start":  "node dist/app.js",
  "build": "tsc",
  "db:sync":  "docker-compose exec api npx ts-node src/db/sync.ts",
  "seed": "docker-compose exec api npx ts-node src/db/seed.ts",
  "scaffold": "ts-node scripts/scaffold-domain.ts",
  "test": "jest --runInBand --forceExit"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "http-errors": "^2.0.1",
    "joi": "^18.0.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
